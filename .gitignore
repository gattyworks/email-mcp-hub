# This repo is a plugin/marketplace — it ships NO user secrets.
# These guard against accidental local credential files during testing.
.env
.env.*
!.env.example
**/credentials/*
!**/credentials/.gitkeep
**/*.creds.json
gcp-oauth.keys.json

# Local Claude settings
.claude/settings.local.json

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
node_modules/
.venv/
__pycache__/
